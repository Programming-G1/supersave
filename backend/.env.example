# Spring profile
spring.profiles.active=postgres

# Gemini
SUPERSAVE_GEMINI_ENABLED=false
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Public emergency data API
PUBLIC_DATA_ENABLED=true
PUBLIC_DATA_SERVICE_KEY=YOUR_PUBLIC_DATA_SERVICE_KEY

# Kakao local API
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL / Supabase
DB_URL=jdbc:postgresql://aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
