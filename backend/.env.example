# Example backend environment variables (do NOT commit secrets)
# Copy this to backend/.env locally and fill with real values

SUPERSAVE_GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

PUBLIC_DATA_ENABLED=true
PUBLIC_DATA_SERVICE_KEY=

# Kakao navigation REST API key (supported env names: KAKAO_REST_API_KEY or SUPERSAVE_KAKAO_NAVIGATION_REST_API_KEY)
KAKAO_REST_API_KEY=
#SUPERSAVE_KAKAO_NAVIGATION_REST_API_KEY=

PUBLIC_DATA_SERVICE_KEY=YOUR_PUBLIC_DATA_SERVICE_KEY

# Kakao local API
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL / Supabase
DB_URL=jdbc:postgresql://aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_MAX_POOL_SIZE=3
DB_MIN_IDLE=1
DB_IDLE_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=600000
DB_CONNECTION_TIMEOUT_MS=10000
