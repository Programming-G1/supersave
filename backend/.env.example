# Example backend environment variables (do NOT commit secrets)
# Copy this to backend/.env locally and fill with real values

SUPERSAVE_GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

PUBLIC_DATA_ENABLED=true
PUBLIC_DATA_SERVICE_KEY=

# Kakao navigation REST API key (supported env names: KAKAO_REST_API_KEY or SUPERSAVE_KAKAO_NAVIGATION_REST_API_KEY)
KAKAO_REST_API_KEY=
#SUPERSAVE_KAKAO_NAVIGATION_REST_API_KEY=
